{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "python -m src.main_hybrid --preferred-hour 20 --weekend-hour 10 --target-time 08:59:59.800",
    "restartPolicyType": "never"
  }
}

